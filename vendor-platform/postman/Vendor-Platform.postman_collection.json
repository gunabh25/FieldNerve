{
  "info": {
    "name": "Vendor Platform API",
    "description": "Vendor, VendorDocument, and WorkRequirement CRUD endpoints for the intelligent vendor recommendation platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "vendorId",
      "value": ""
    },
    {
      "key": "documentId",
      "value": ""
    },
    {
      "key": "workRequirementId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Vendors",
      "item": [
        {
          "name": "List All Vendors",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vendors"
          }
        },
        {
          "name": "List Vendors (filtered)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/vendors?status=ACTIVE&category=Electrical&vendorType=Contractor",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendors"],
              "query": [
                { "key": "status", "value": "ACTIVE" },
                { "key": "category", "value": "Electrical" },
                { "key": "vendorType", "value": "Contractor" }
              ]
            }
          }
        },
        {
          "name": "Create Vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('vendorId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"vendorType\": \"Contractor\",\n  \"category\": \"Electrical\",\n  \"contactName\": \"John Doe\",\n  \"email\": \"john@acme.com\",\n  \"phone\": \"555-0100\",\n  \"operatingLocation\": \"Austin, TX\",\n  \"rating\": 4.5\n}"
            },
            "url": "{{baseUrl}}/api/vendors"
          }
        },
        {
          "name": "Get Vendor by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}"
          }
        },
        {
          "name": "Update Vendor",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4.8,\n  \"status\": \"INACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}"
          }
        },
        {
          "name": "Delete Vendor",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}"
          }
        }
      ]
    },
    {
      "name": "Vendor Documents",
      "item": [
        {
          "name": "List Documents by Vendor",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}/documents"
          }
        },
        {
          "name": "List Documents (filtered)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/vendors/{{vendorId}}/documents?documentType=LICENSE&isVerified=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vendors", "{{vendorId}}", "documents"],
              "query": [
                { "key": "documentType", "value": "LICENSE" },
                { "key": "isVerified", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Create Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('documentId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentType\": \"LICENSE\",\n  \"expiryDate\": \"2027-12-31\",\n  \"isVerified\": false\n}"
            },
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}/documents"
          }
        },
        {
          "name": "Get Document by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}/documents/{{documentId}}"
          }
        },
        {
          "name": "Update Document",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isVerified\": true,\n  \"expiryDate\": \"2028-06-30\"\n}"
            },
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}/documents/{{documentId}}"
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/vendors/{{vendorId}}/documents/{{documentId}}"
          }
        }
      ]
    },
    {
      "name": "Work Requirements",
      "item": [
        {
          "name": "List All Work Requirements",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/work-requirements"
          }
        },
        {
          "name": "List Work Requirements (filtered)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/work-requirements?category=Construction&priority=HIGH&location=Austin, TX",
              "host": ["{{baseUrl}}"],
              "path": ["api", "work-requirements"],
              "query": [
                { "key": "category", "value": "Construction" },
                { "key": "priority", "value": "HIGH" },
                { "key": "location", "value": "Austin, TX" }
              ]
            }
          }
        },
        {
          "name": "Create Work Requirement",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('workRequirementId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Office Renovation\",\n  \"category\": \"Construction\",\n  \"location\": \"Austin, TX\",\n  \"estimatedValue\": 50000,\n  \"expectedStartDate\": \"2026-08-01\",\n  \"priority\": \"HIGH\"\n}"
            },
            "url": "{{baseUrl}}/api/work-requirements"
          }
        },
        {
          "name": "Get Work Requirement by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/work-requirements/{{workRequirementId}}"
          }
        },
        {
          "name": "Update Work Requirement",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estimatedValue\": 75000,\n  \"priority\": \"MEDIUM\",\n  \"expectedStartDate\": \"2026-09-15\"\n}"
            },
            "url": "{{baseUrl}}/api/work-requirements/{{workRequirementId}}"
          }
        },
        {
          "name": "Delete Work Requirement",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/work-requirements/{{workRequirementId}}"
          }
        }
      ]
    }
  ]
}
